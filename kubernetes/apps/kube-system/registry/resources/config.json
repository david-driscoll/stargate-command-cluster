{
  "distSpecVersion": "1.1.0",
  "storage": {
    "rootDirectory": "/var/lib/registry",
    "commit": true,
    "gc": true,
    "gcDelay": "1h",
    "gcInterval": "6h"
  },
  "http": {
    "address": "0.0.0.0",
    "port": "8080"
  },
  "log": { "level": "info" },
  "extensions": {
    "ui": {
      "enable": true
    },
    "search": {
      "enable": true,
      "cve": {
        "updateInterval": "168h"
      }
    },
    "scrub": {
      "enable": true,
      "interval": "24h"
    },
    "metrics": {
      "enable": true,
      "prometheus": {
        "path": "/metrics"
      }
    },
    "sync": {
      "enable": true,
      "registries": [
        {
          "urls": ["https://index.docker.io", "https://registry-1.docker.io"],
          "tlsVerify": true,
          "onDemand": true,
          "maxRetries": 3,
          "retryDelay": "15m",
          "onlySigned": false,
          "content": [
            {
              "prefix": "library/**",
              "destination": "/docker.io",
              "deleteUntagged": true
            },
            {
              "prefix": "**",
              "destination": "/docker.io",
              "deleteUntagged": true
            }
          ]
        },
        {
          "urls": ["https://quay.io"],
          "tlsVerify": true,
          "onDemand": true,
          "maxRetries": 3,
          "retryDelay": "15m",
          "onlySigned": false,
          "content": [
            {
              "prefix": "**",
              "destination": "/quay.io",
              "deleteUntagged": true
            }
          ]
        },
        {
          "urls": ["https://gcr.io"],
          "tlsVerify": true,
          "onDemand": true,
          "maxRetries": 3,
          "retryDelay": "15m",
          "onlySigned": false,
          "content": [
            {
              "prefix": "**",
              "destination": "/gcr.io",
              "deleteUntagged": true
            }
          ]
        },
        {
          "urls": ["https://ghcr.io"],
          "tlsVerify": true,
          "onDemand": true,
          "maxRetries": 3,
          "retryDelay": "15m",
          "onlySigned": false,
          "content": [
            {
              "prefix": "**",
              "destination": "/ghcr.io",
              "deleteUntagged": true
            }
          ]
        },
        {
          "urls": ["https://registry.k8s.io"],
          "tlsVerify": true,
          "onDemand": true,
          "maxRetries": 3,
          "retryDelay": "15m",
          "onlySigned": false,
          "content": [
            {
              "prefix": "**",
              "destination": "/registry.k8s.io",
              "deleteUntagged": true
            }
          ]
        },
        {
          "urls": ["https://public.ecr.aws"],
          "tlsVerify": true,
          "onDemand": true,
          "maxRetries": 3,
          "retryDelay": "15m",
          "onlySigned": false,
          "content": [
            {
              "prefix": "**",
              "destination": "/public.ecr.aws",
              "deleteUntagged": true
            }
          ]
        },
        {
          "urls": ["https://cgr.dev"],
          "tlsVerify": true,
          "onDemand": true,
          "maxRetries": 3,
          "retryDelay": "15m",
          "onlySigned": false,
          "content": [
            {
              "prefix": "**",
              "destination": "/cgr.dev",
              "deleteUntagged": true
            }
          ]
        },
        {
          "urls": ["https://mcr.microsoft.com"],
          "tlsVerify": true,
          "onDemand": true,
          "maxRetries": 3,
          "retryDelay": "15m",
          "onlySigned": false,
          "content": [
            {
              "prefix": "**",
              "destination": "/mcr.microsoft.com",
              "deleteUntagged": true
            }
          ]
        }
      ]
    }
  }
}
